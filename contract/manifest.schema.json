{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gnaw.dev/contract/manifest.schema.json",
  "title": "Gnaw manifest v2",
  "description": "MANIFEST.json written at the end of every valid Gnaw haul.",
  "type": "object",
  "required": [
    "schemaVersion",
    "gnawVersion",
    "engine",
    "entrypoint",
    "host",
    "startedAt",
    "finishedAt",
    "durationMs",
    "result",
    "modes",
    "config",
    "stack",
    "stats",
    "pages",
    "assets",
    "safety",
    "errors"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "gnawVersion": { "type": "string" },
    "engine": {
      "type": "object",
      "required": ["name", "version", "browser"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "browser": { "type": "string" }
      },
      "additionalProperties": true
    },
    "entrypoint": { "type": "string" },
    "host": { "type": "string" },
    "startedAt": { "type": "string" },
    "finishedAt": { "type": "string" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "result": {
      "type": "string",
      "enum": ["complete", "partial", "canceled"]
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["navigable", "study"]
      },
      "minItems": 1
    },
    "config": {
      "type": "object",
      "required": [
        "depth",
        "sameDomainOnly",
        "includeSubdomains",
        "respectRobots",
        "rateLimitMs",
        "maxPages",
        "maxTotalBytes",
        "maxAssetBytes",
        "userAgent",
        "authProfile"
      ],
      "properties": {
        "depth": { "type": "integer", "minimum": 0 },
        "sameDomainOnly": { "type": "boolean" },
        "includeSubdomains": { "type": "boolean" },
        "respectRobots": { "type": "boolean" },
        "rateLimitMs": { "type": "integer", "minimum": 0 },
        "maxPages": { "type": "integer", "minimum": 0 },
        "maxTotalBytes": { "type": "integer", "minimum": 0 },
        "maxAssetBytes": { "type": "integer", "minimum": 0 },
        "userAgent": { "type": "string" },
        "authProfile": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "stack": {
      "type": "object",
      "required": ["primary", "detected"],
      "properties": {
        "primary": { "type": ["string", "null"] },
        "detected": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "confidence", "signals"],
            "properties": {
              "name": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0 },
              "signals": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "stats": {
      "type": "object",
      "required": ["pages", "assets", "bytes", "byKind"],
      "properties": {
        "pages": { "type": "integer", "minimum": 0 },
        "assets": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 },
        "byKind": {
          "type": "object",
          "required": ["HTML", "JS", "CSS", "IMG", "FONT", "JSON", "MEDIA", "WASM", "OTHER"],
          "properties": {
            "HTML": { "type": "integer", "minimum": 0 },
            "JS": { "type": "integer", "minimum": 0 },
            "CSS": { "type": "integer", "minimum": 0 },
            "IMG": { "type": "integer", "minimum": 0 },
            "FONT": { "type": "integer", "minimum": 0 },
            "JSON": { "type": "integer", "minimum": 0 },
            "MEDIA": { "type": "integer", "minimum": 0 },
            "WASM": { "type": "integer", "minimum": 0 },
            "OTHER": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "title", "depth", "status", "discoveredFrom"],
        "properties": {
          "url": { "type": "string" },
          "title": { "type": "string" },
          "depth": { "type": "integer", "minimum": 0 },
          "status": { "type": "integer", "minimum": 0 },
          "discoveredFrom": { "type": ["string", "null"] },
          "navigablePath": { "type": "string" },
          "renderedPath": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "kind", "status", "contentType", "bytes", "sha256", "rawPath", "referrer", "viaJs", "fromCache"],
        "properties": {
          "url": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["HTML", "JS", "CSS", "IMG", "FONT", "JSON", "MEDIA", "WASM", "OTHER"]
          },
          "status": { "type": "integer", "minimum": 0 },
          "contentType": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string" },
          "rawPath": { "type": "string" },
          "beautifiedPath": { "type": "string" },
          "referrer": { "type": ["string", "null"] },
          "viaJs": { "type": "boolean" },
          "fromCache": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "auth": {
      "type": "object",
      "required": ["mode", "profileName", "storageStateUsed", "redacted"],
      "properties": {
        "mode": { "type": "string", "enum": ["profile"] },
        "profileName": { "type": "string" },
        "storageStateUsed": { "type": "boolean" },
        "redacted": { "const": true }
      },
      "additionalProperties": true
    },
    "safety": {
      "type": "object",
      "required": ["skippedUrls"],
      "properties": {
        "skippedUrls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "reason"],
            "properties": {
              "url": { "type": "string" },
              "reason": {
                "type": "string",
                "enum": ["blocked_pattern", "out_of_scope", "robots", "max_pages", "max_depth"]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "url": { "type": "string" },
          "message": { "type": "string" },
          "fatal": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
