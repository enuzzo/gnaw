{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": [
    "engine/src/**/*.ts",
    "engine/test/**/*.ts",
    "fixtures/src/**/*.ts",
    "harness/src/**/*.ts",
    "harness/test/**/*.ts",
    "vitest.config.ts"
  ]
}
